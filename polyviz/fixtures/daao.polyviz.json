      { "from": "EXECUTED", "event": "close", "guard": "", "to": "CLOSED", "effect": "" },
      { "from": "PENDING_APPROVAL", "event": "abort", "guard": "", "to": "ABORTED", "effect": "" },
      { "from": "PENDING_APPROVAL", "event": "expire", "guard": "now>window.end", "to": "EXPIRED", "effect": "" }
    ]
  },
  "invariants": [
    { "id": "S1", "kind": "safety", "text": "Never execute without two distinct approvers (neither the proposer)", "status": "pass" },
    { "id": "S2", "kind": "safety", "text": "Never execute outside the authorized time window", "status": "pass" },
    { "id": "S3", "kind": "safety", "text": "Never execute twice — exactly once, even after a crash or a retry", "status": "pass" },
    { "id": "S4", "kind": "safety", "text": "Never lose an order once it has been acknowledged", "status": "pass" },
    { "id": "S5", "kind": "safety", "text": "Never manufacture authorization by looping back through the graph", "status": "pass" },
    { "id": "L1", "kind": "liveness", "text": "Recall stays reachable until execution", "status": "pass" },
    { "id": "L2", "kind": "liveness", "text": "Every order eventually reaches a terminal state", "status": "pass" }
